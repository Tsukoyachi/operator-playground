# Normalize line endings for all text files
* text=auto eol=lf

# Force LF for shell scripts (critical for Docker/K8s)
*.sh text eol=lf

# Force LF for Kubernetes / Helm / YAML (avoids CRLF issues in containers/tools)
*.yml text eol=lf
*.yaml text eol=lf

# Java sources (optional but safe consistency)
*.java text eol=lf
*.xml text eol=lf
*.properties text eol=lf
*.md text eol=lf

# Keep binary files untouched
*.jar binary
*.png binary
*.jpg binary